# Sample config for the zerogex-alert@.service template dispatcher.
#
# Install location: /etc/zerogex/alert.env  (chmod 640, owner root:ubuntu)
#
# Pick ONE backend by setting ALERT_BACKEND, then fill in the matching
# secret(s) below.  Leave the rest commented out.
#
# Smoke test after install:
#   make alert-template-test
# (writes a synthetic alert to the chosen backend; defaults to stderr,
# which lands in `journalctl -u zerogex-alert@*`).

# ---------------------------------------------------------------------------
# stderr — default; logs to systemd journal of the alert unit.
# ---------------------------------------------------------------------------
ALERT_BACKEND=stderr

# ---------------------------------------------------------------------------
# slack — incoming-webhook URL.  Create one at:
#   https://api.slack.com/messaging/webhooks
# ---------------------------------------------------------------------------
#ALERT_BACKEND=slack
#SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXXXXX

# ---------------------------------------------------------------------------
# sns — AWS Simple Notification Service topic (host needs IAM permission
# `sns:Publish` on the topic; AWS CLI must be installed and configured).
# Subscribers (email / SMS / Lambda / SQS) are managed in the AWS console.
# ---------------------------------------------------------------------------
#ALERT_BACKEND=sns
#SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:zerogex-alerts

# ---------------------------------------------------------------------------
# pagerduty — Events API v2.  Use an "Events API V2" integration on a
# service in PagerDuty and copy the integration key here.  Failure events
# are sent with action=trigger and dedup_key=<unit>@<host> so duplicate
# triggers from the same unit on the same host fold into one incident.
# ---------------------------------------------------------------------------
#ALERT_BACKEND=pagerduty
#PAGERDUTY_ROUTING_KEY=R0000000000000000000000000000000

# ---------------------------------------------------------------------------
# webhook — generic POST of {unit, host, timestamp, journal_tail} JSON to
# any receiver (Datadog event API, Opsgenie, custom relay, etc.).
# ---------------------------------------------------------------------------
#ALERT_BACKEND=webhook
#WEBHOOK_URL=https://example.com/alerts/zerogex

###########################################################################################################
# Deploy-time configuration
#
# Used by deploy/deploy.sh and the steps under deploy/steps/ to provision a fresh
# instance.  Not read by the application at runtime.
#
# OA_API_DOMAIN       — public hostname for the API (used by nginx + Let's Encrypt).
#                       The DNS A record for this name MUST point to the instance's
#                       public IP before step 130 runs.
# LETSENCRYPT_EMAIL   — email address Let's Encrypt uses for renewal/expiry notices.
#
###########################################################################################################
OA_API_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=ops@example.com

###########################################################################################################
# TradeStation API Parameters
# Documentation: https://api.tradestation.com/docs/fundamentals/authentication/auth-overview/
#
# TRADESTATION_CLIENT_ID     - "client ID" or "API key" provided by TradeStation
# TRADESTATION_CLIENT_SECRET - secret for the API key provided by TradeStation - can be rotated by
#                              contacting Client Service
# TRADESTATION_REFRESH_TOKEN - refresh token granted during the authorization code flow (see
#                              https://api.tradestation.com/docs/fundamentals/authentication/refresh-tokens
#                              for complete specifications
#
###########################################################################################################
TRADESTATION_CLIENT_ID=xxxxxxxxxx
TRADESTATION_CLIENT_SECRET=xxxxxxxxxx
TRADESTATION_REFRESH_TOKEN=xxxxxxxxxx

# Use sandbox/simulation environment (true) or production (false)
# Default: false
TRADESTATION_USE_SANDBOX=false

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# LOG_FORMAT: controls log output shape.
#   text  (default) — plain "<asctime> - <name> - <level> - [request_id=...] <msg>"
#                     Best for local dev / journalctl tailing.
#   json            — one JSON object per line, with timestamp/level/name/message
#                     plus request_id. Best for production where logs are shipped
#                     to an aggregator (CloudWatch / Datadog / ELK).
# request_id is set by RequestIdMiddleware on every API request; background
# tasks with no request context log request_id="-".
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# API Authentication & Environment
# -----------------------------------------------------------------------------
# Deployment environment. Enables prod-only guardrails:
#   - Refuses to start with wildcard/empty CORS_ALLOW_ORIGINS
#   - Logs ERROR (not INFO) when API_KEY is missing
# Valid values: development | staging | production
# Default: development
ENVIRONMENT=development

# LEGACY break-glass shared secret.  When set, requests carrying this key
# in ``X-API-Key`` or ``Authorization: Bearer`` are accepted with no
# per-user attribution.  Kept for ops emergencies and bootstrap; the
# primary mechanism is per-user keys in the ``api_keys`` table:
#   make api-keys-create USER=<user_id> NAME=<label>
# (or ``python -m src.api.admin_keys create ...``).  Both mechanisms
# coexist; remove this line entirely once every caller (website, scripts,
# integrations) has its own per-user key.
# Generate one with:  python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
#
# Note: nginx no longer auto-injects this key on requests it proxies — every
# caller (browser, Swagger UI, server-side fetch) must send the header itself.
API_KEY=

# Per-user API key used by local ops tooling on this box — `make api-test`,
# `make staging-smoke`, and any other Makefile target that needs to hit a
# protected endpoint from the server itself.  Distinct from the website's
# key so ops calls show up as their own user_id in audit logs and can be
# revoked independently.
#
# Mint once with:
#   make api-keys-create USER=ops NAME=ops-make-tests
# then paste the printed key here.  Falls back to API_KEY above if unset,
# so existing break-glass deployments keep working.
OPS_API_KEY=

# Optional: how long (seconds) the API process caches successful per-user
# key lookups before re-checking the api_keys table.  Lower values pick up
# revocations faster at the cost of more DB round-trips.  Default: 60.
# API_KEY_CACHE_TTL_SECONDS=60

# Optional: minimum seconds between last_used_at touches for the same key,
# per worker.  Lower values give finer-grained activity timestamps at the
# cost of more UPDATE writes during sustained traffic.  Default: 60.
# API_KEY_TOUCH_THROTTLE_SECONDS=60

# End-user attribution for website-proxied requests. The website calls
# this API with one shared key (user_id=zerogex-web) on behalf of every
# logged-in human; when this secret is set it also verifies a short-lived
# HS256 JWT in the X-End-User-Token header and attaches the end-user to
# the request identity (audit logs + optional rate limiting).
#
# Must be byte-identical to the website's ZEROGEX_END_USER_TOKEN_SECRET.
# Generate one with:  python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
#
# UNSET = attribution disabled = caller-only behavior (exactly as before).
# Verification is pure crypto and fail-open: a missing/invalid/expired/
# forged token NEVER rejects the request — it just means "no end-user".
END_USER_TOKEN_SECRET=

# Optional attribution tunables (defaults shown):
#   LEEWAY  — clock-skew tolerance, seconds.
#   MAX_AGE — honored token lifetime is hard-capped this many seconds
#             from iat, regardless of exp.
# END_USER_TOKEN_LEEWAY_SECONDS=60
# END_USER_TOKEN_MAX_AGE_SECONDS=900

# Identity-keyed rate limiting (keyed end-user > caller > IP).
# ENABLED alone = log-only (counts + WOULD-BLOCK warning, never rejects);
# add ENFORCE=true to return 429 over the limit. Counter is in-memory
# fixed-window per worker — effective per-key ceiling is REQUESTS × the
# uvicorn worker count (see setup/systemd/zerogex-oa-api.service).
END_USER_RATE_LIMIT_ENABLED=true
# END_USER_RATE_LIMIT_ENFORCE=false
END_USER_RATE_LIMIT_REQUESTS=600
END_USER_RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated CORS allowlist for the API.
# In production this MUST be set to an explicit list; the service will
# refuse to start with wildcard or empty CORS when ENVIRONMENT=production.
# Example: CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=

# Comma-separated set of trusted reverse-proxy IPs for rate-limit client-IP
# resolution. When the direct peer is in this set, the limiter reads the client
# IP from X-Forwarded-For (walking right-to-left to the first untrusted hop)
# instead of the proxy IP; otherwise it keys strictly on the direct peer.
# 127.0.0.1 covers the bundled nginx that terminates TLS on the loopback
# (see deploy/steps/120.nginx_api). If you add an upstream CDN/ALB in front
# of nginx, append its egress IPs here so the chain walks through to the
# real client; otherwise the limiter stops at the CDN edge.
RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1

# -----------------------------------------------------------------------------
# Market Hours Warnings
# -----------------------------------------------------------------------------
# Show warnings when fetching data while market is closed
# Set to 'false' to suppress warnings globally
# Default: true
TS_WARN_MARKET_HOURS=true

# -----------------------------------------------------------------------------
# TradeStation Client Test Configuration
# -----------------------------------------------------------------------------
# These control the behavior of: python -m src.ingestion.tradestation_client
# Command-line arguments override these settings

# Which test to run: all, quote, bars, stream-bars, options, options-expirations, options-strikes, option-quote, search, market-hours, depth
# Default: all
TS_TEST=all

# Symbol(s) to test with (comma-separated for multiple)
# Default: SPY
# Supports aliases if SYMBOL_ALIASES is configured below (e.g., SPX)
TS_SYMBOL=SPY

# Number of bars to retrieve
# Default: 5
TS_BARS_BACK=5

# Bar interval (1, 5, 15, 60, etc.)
# Default: 1
TS_INTERVAL=1

# Bar time unit: Minute, Daily, Weekly, Monthly
# Default: Daily
TS_UNIT=Daily

# Search query for symbol search test
# Default: Apple
TS_QUERY=Apple

# -----------------------------------------------------------------------------
# Shared Symbol Resolution Configuration (used by ingestion, analytics, and CLI tests)
# -----------------------------------------------------------------------------
# Symbol aliases: human-friendly alias -> TradeStation underlying symbol.
# The alias is stored in the database and used in the API/analytics.
# The resolved TradeStation symbol is used for: underlying bars, option
# expirations, and option strikes lookups.
# Format: ALIAS=TS_SYMBOL,ALIAS2=TS_SYMBOL2
#
# SPX NOTE: Use $SPXW.X (not $SPX.X) as the TS symbol for SPX weekly options.
# TradeStation fetches expirations and strikes under $SPXW.X, and option quotes
# are built with root "SPXW" (e.g. "SPXW 260320C6630"). See OPTION_ROOT_ALIASES.
#
# Example: SYMBOL_ALIASES=SPX=$SPXW.X,NDX=$NDX.X
SYMBOL_ALIASES=

# Option-root overrides: TradeStation underlying symbol -> option chain root.
# Used ONLY when constructing option chain symbol strings for get_option_quotes().
# e.g. "$SPXW.X=SPXW" means expirations/strikes are fetched using "$SPXW.X" and
# option quotes are built as "SPXW 260320C6630".
# Format: TS_SYMBOL=OPTION_ROOT
# Example: OPTION_ROOT_ALIASES=$SPXW.X=SPXW,$SPX.X=SPX
OPTION_ROOT_ALIASES=

# Monthly chain TS symbol per canonical underlying. Format: CANONICAL=TS_SYMBOL,...
# Used together with INGEST_MONTHLY_EXPIRATIONS to layer AM-settled monthly
# expirations on TOP of the weekly window. The weekly chain stays wired via
# SYMBOL_ALIASES + OPTION_ROOT_ALIASES; this entry tells ingestion which TS
# symbol to ALSO query for the monthly expansion. Without this, monthly SPX
# (and other index) options never reach option_chains regardless of how
# large INGEST_EXPIRATIONS is set, because the weekly chain ($SPXW.X) only
# lists weeklies.
#
# SPX example (paired with the SYMBOL_ALIASES + OPTION_ROOT_ALIASES above):
#   INGEST_MONTHLY_UNDERLYING_ALIASES=SPX=$SPX.X
#   OPTION_ROOT_ALIASES=$SPXW.X=SPXW,$SPX.X=SPX
# Weekly quotes flow as "SPXW 260320C6630"; monthly quotes flow as
# "SPX 260320C6630". Both land in option_chains.underlying='SPX'.
INGEST_MONTHLY_UNDERLYING_ALIASES=


# -----------------------------------------------------------------------------
# API Request Configuration
# -----------------------------------------------------------------------------
# Timeout for API requests (seconds)
# Default: 30
API_REQUEST_TIMEOUT=30

# Read timeout for long-lived TradeStation stream connections (seconds)
# This should generally be higher than API_REQUEST_TIMEOUT to avoid reconnect churn.
# Default: 300
TS_STREAM_READ_TIMEOUT=300

# Access-token refresh buffer (seconds).
# Refresh only when token is this close to expiry in normal request paths.
# Default: 30
TS_REFRESH_BUFFER_SECONDS=30

# Minimum interval between force-refresh attempts (seconds).
# Prevents refresh storms when multiple stream auth errors arrive together.
# Default: 60
TS_MIN_FORCE_REFRESH_INTERVAL_SECONDS=60

# Reuse persistent HTTP stream connections for the underlying bar stream
# snapshot reads.  Default: false (each bar poll opens/closes a connection).
TS_STREAM_REUSE_CONNECTIONS=false

# Only relevant when using the client's get_stream_quotes() directly.
# The OptionStreamAccumulator manages its own persistent connection.
# Default: false
TS_STREAM_REUSE_QUOTES=false

# Number of retry attempts for failed requests
# Default: 3
API_RETRY_ATTEMPTS=3

# Initial delay between retries (seconds)
# Default: 1.0
API_RETRY_DELAY=1.0

# Backoff multiplier for exponential retry delay
# Example: attempt 1 = 1s, attempt 2 = 2s, attempt 3 = 4s
# Default: 2.0
API_RETRY_BACKOFF=2.0

# --- TradeStation rate-limit governor -----------------------------------
# Cap on combined API call volume across ALL ingestion processes in each
# 5-minute UTC window.  Each TradeStationClient checks the persisted total
# in tradestation_api_calls plus its own in-flight count; when it meets the
# cap, the next request blocks until the next 5-min boundary instead of
# hammering the upstream with 429s.  TradeStation's production cap is ~1000
# per 5-min on the standard account, so 900 leaves headroom.  Set to 0 to
# disable the governor (revert to the previous best-effort retry behavior).
# Default: 900
TS_RATE_LIMIT_PER_5MIN=900

# How often (seconds) each process pushes its in-flight partial count to
# tradestation_api_calls AND re-reads the cross-process total.  Lower =
# tighter coordination but more DB chatter.  Default: 5
TS_RATE_LIMIT_SYNC_INTERVAL=5

# Strikes endpoint cache TTL (seconds).  Strike chains barely change
# intraday for liquid underlyings, so the full list returned by
# /marketdata/options/strikes/{symbol}?expiration=... is cached per
# (underlying, expiration) for this many seconds.  Set to 0 to disable
# (fetch every call).  Default: 3600 (1 hour).
TS_STRIKES_CACHE_TTL=3600

# --- TradeStation response-header rate-limit gate ----------------------
# TradeStation publishes per-resource quota state on every response via
# X-RateLimit-Limit/Period/Remaining/Reset/Resource (see TradeStation API
# docs, "Rate Limiting Overview").  When enabled, the client parses those
# headers and gates subsequent requests against the observed remaining
# quota -- strictly better than the static cap above, which is a coarse
# approximation of TradeStation's actual rolling per-resource limits.
# The static cap remains as a defense-in-depth fallback for cold-start
# windows and as an escape hatch for malformed headers.
#
# Master switch.  Set False to disable the header gate and rely solely
# on the static cap + retry path.  Default: True
TS_RATE_LIMIT_HEADER_GATE_ENABLED=True

# Pre-emptive sleep threshold.  When a resource's X-RateLimit-Remaining
# drops to this value, the client sleeps until X-RateLimit-Reset instead
# of consuming the last request(s) and risking a 429.  Default: 1
# (sleep only when budget is fully exhausted).
TS_RATE_LIMIT_HEADER_MIN_REMAINING=1

# Discard a resource's cached state after this many seconds with no
# fresh observation, so we don't gate on stale data after a long quiet
# period.  TradeStation's longest documented period is 300s (5 min);
# 600 is comfortably past that.  Default: 600
TS_RATE_LIMIT_HEADER_STALE_SECONDS=600

# Batch size for quote requests (max 500 per TradeStation API)
# Default: 100
QUOTE_BATCH_SIZE=100

# Batch size for option quote requests
# Default: 100
OPTION_BATCH_SIZE=100

# Delay between batches of requests (seconds)
# Default: 0.5
DELAY_BETWEEN_BATCHES=0.5

# Delay between processing bars (seconds)
# Default: 1.0
DELAY_BETWEEN_BARS=1.0

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Database connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zerogex
DB_USER=postgres

# Database password provider: 'pgpass', 'aws_secrets_manager', or 'env'
#
# RECOMMENDED: 'pgpass' (default)
# - Uses ~/.pgpass file (PostgreSQL standard)
# - No password in code or environment variables
# - Secure file permissions (600) enforced by PostgreSQL
# - Setup:
#     1. Create ~/.pgpass with: hostname:port:database:username:password
#     2. Set permissions: chmod 600 ~/.pgpass
#
# For AWS RDS: 'aws_secrets_manager'
# - Retrieves password from AWS Secrets Manager
# - Requires DB_SECRET_NAME and AWS_REGION
#
# For development only: 'env'
# - Reads password directly from DB_PASSWORD
# - NOT RECOMMENDED for production
#
# Default: pgpass
DB_PASSWORD_PROVIDER=pgpass

# If using 'env' provider (NOT RECOMMENDED for production)
DB_PASSWORD=

# If using 'aws_secrets_manager' provider
DB_SECRET_NAME=
AWS_REGION=us-east-1

# Connection pool configuration
# Each service (API, signal engine, ingestion) creates its own pool.
# Keep max low to avoid exhausting RDS max_connections.
# Default min: 1, max: 4 (sync) / 8 (async API)
DB_POOL_MIN=1
DB_POOL_MAX=4

# API async DB connect timeout (seconds)
# Default: 20
DB_CONNECT_TIMEOUT_SECONDS=20

# Connection retry behavior for DB bootstrap/startup paths.
# Defaults: retries=5, retry delay base=1.5 seconds.
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_SECONDS=1.5

# Optional PostgreSQL SSL mode (disable, require, verify-ca, verify-full).
# Default: empty (driver default).
DB_SSLMODE=

# PostgreSQL statement_timeout (milliseconds) enforced on every pooled
# connection (both the asyncpg API pool and the psycopg2 analytics pool).
# Sized for AnalyticsEngine._get_snapshot at the 96-hour lookback, which
# runs ~40-45s under concurrent production load even with the partial
# covering index in place (DISTINCT ON over the window walks ~400k tuples
# regardless of available indexes -- PostgreSQL has no skip-scan).  Set to
# 0 to disable the cap entirely (not recommended in production).
# Default: 90000 (90 seconds).
DB_STATEMENT_TIMEOUT_MS=90000

# PostgreSQL TCP keepalive tuning for long-lived connections.
# Defaults: idle=30s, interval=10s, count=5.
DB_KEEPALIVES_IDLE_SECONDS=30
DB_KEEPALIVES_INTERVAL_SECONDS=10
DB_KEEPALIVES_COUNT=5

# Data retention period (days) for option_chains and the other timestamped
# tables pruned by `make db-prune` (the daily db-maintain timer).
# 60 covers every recurring reader with wide margin: the live engines read only
# the current/prior session, the heaviest rolling query spans ~4 days, and the
# derived rollups (flow_by_contract, gex_summary, signal_scores, daily_atm_iv)
# persist independently of option_chains. 60 also lets the one-shot daily_atm_iv
# backfill re-seed a full 30 *trading* days (~42 calendar) of iv_rank after a
# from-scratch rebuild. Drop toward ~30 to trim harder if that re-seed isn't needed.
#
# NOTE: option_chains_archive is NOT subject to this prune (it is deliberately
# excluded from DB_MAINTAIN_TABLES). The nightly `make backtest-archive` job
# (zerogex-oa-backtest-archive.timer) copies option_chains into it so the
# backtesting platform can price option legs past this horizon.
DATA_RETENTION_DAYS=60

# -----------------------------------------------------------------------------
# Main Ingestion Engine Configuration (Real-Time Forward Data)
# Used by: make ingestion-start / make run-ingest / make run-stream
# -----------------------------------------------------------------------------
# Underlying symbol or alias (e.g. SPY, SPX). Aliases are resolved to their
# TradeStation symbols via SYMBOL_ALIASES for API calls, but the alias is what
# gets stored in the database.
# Default: SPY
INGEST_UNDERLYING=SPY

# Multi-symbol ingestion (comma-separated, overrides INGEST_UNDERLYING when set)
# Example: INGEST_UNDERLYINGS=SPY,SPX
INGEST_UNDERLYINGS=

# Signals engine underlying symbols (comma-separated)
# Default: SPY
SIGNALS_UNDERLYINGS=SPY

# -----------------------------------------------------------------------------
# Playbook pattern calibration (empirical-base feedback loop)
# See docs/design/pattern-calibration.md. OFF by default — enabling it makes the
# live engine replace each pattern's hand-set pattern_base prior with the win
# rate measured by the playbook backtest (playbook_pattern_stats.proposed_base),
# so live Action Card confidence reflects measured edge. Refreshed nightly by
# zerogex-oa-pattern-calibration.timer (`make pattern-calibration-refresh`).
# -----------------------------------------------------------------------------
SIGNALS_PATTERN_CALIBRATION_ENABLED=0
# Min resolved trades in a (pattern, underlying) window before it's trusted.
SIGNALS_PATTERN_CALIBRATION_MIN_SAMPLES=20
# Ignore stats windows whose end date is older than this many days.
SIGNALS_PATTERN_CALIBRATION_MAX_AGE_DAYS=45
# Clamp band for the calibrated base (mirrors the catalog's pattern_base band).
SIGNALS_PATTERN_CALIBRATION_FLOOR=0.40
SIGNALS_PATTERN_CALIBRATION_CEIL=0.85
# How often the live signals process reloads the calibration store (seconds).
SIGNALS_PATTERN_CALIBRATION_REFRESH_SECONDS=21600
# Days of history each nightly calibration backtest scans.
SIGNALS_PATTERN_CALIBRATION_LOOKBACK_DAYS=60

# Backtesting platform: minimum minutes between consecutive entries of the same
# pattern. The live engine emits a card nearly every cycle; this collapses that
# stream into discrete trades (realism + performance). 0 prices every card.
# Per-request overridable via the BacktestSpec "cooldown_minutes" field.
BACKTEST_SIGNAL_COOLDOWN_MINUTES=30

# Backtest worker (Phase 4): when 1, the API only enqueues runs and the
# standalone worker (`make backtest-worker` / zerogex-oa-backtest-worker.service)
# executes them, so long runs survive API restarts and don't tie up an API
# thread. 0 (default) = API runs them in-process via BackgroundTasks. Only set
# to 1 together with a running worker, or runs will sit queued.
BACKTEST_WORKER_ENABLED=0
BACKTEST_WORKER_POLL_SECONDS=2.0
BACKTEST_WORKER_STALE_MINUTES=30

# Portfolio size used by the position optimizer for sizing budgets.
# Default: 1000000 ($1,000,000)
SIGNALS_PORTFOLIO_SIZE=1000000

# Portfolio-level risk controls for the position optimizer.
# Defaults: max trades=3, max heat=0.06, cooldown=30 minutes, stop loss=-0.25
SIGNALS_MAX_OPEN_TRADES=3
SIGNALS_MAX_PORTFOLIO_HEAT_PCT=0.06
SIGNALS_SAME_DIRECTION_COOLDOWN_MINUTES=30
SIGNALS_STOP_LOSS_PCT=-0.25

# Signal activation sensitivity controls.
# SIGNALS_TRIGGER_THRESHOLD is the conviction (normalized MSI 0..1) required
# to OPEN a fresh position. Higher = fewer, higher-quality entries.
# SIGNALS_EXIT_THRESHOLD is the lower hysteresis bar: an already-open position
# in the same direction is held until conviction drops below this. The gap
# between the two suppresses whipsaws when MSI oscillates around the trigger.
# SIGNALS_CONVICTION_FLOOR rejects candidates where kelly × conviction is
# below this floor, killing technically-positive-but-tiny-edge fills.
# Defaults: trigger=0.60, exit=0.45, conviction floor=0.05, trend bars=3,
# min matching bars=1
SIGNALS_TRIGGER_THRESHOLD=0.60
SIGNALS_EXIT_THRESHOLD=0.45
SIGNALS_CONVICTION_FLOOR=0.05
SIGNALS_TREND_CONFIRMATION_BARS=3
SIGNALS_TREND_CONFIRMATION_MIN_MATCH=1

# Position lifecycle controls.
# SIGNALS_MIN_HOLD_SECONDS protects a freshly-opened position from being
# closed by reconcile churn. Stops/targets still fire inside this window.
# SIGNALS_TARGET_PCT defines the per-trade profit target as a fraction of
# the entry premium (0.50 = +50% on debit, ~1.5R take-profit). 0 disables.
# SIGNALS_TIME_STOP_MINUTES forces a flat at this age regardless of P&L.
# 0 disables. SIGNALS_STOP_LOSS_PCT (above) defines the stop side.
# Defaults: min hold=90s, target=+50%, time stop=60 minutes
SIGNALS_MIN_HOLD_SECONDS=90
SIGNALS_TARGET_PCT=0.50
SIGNALS_TIME_STOP_MINUTES=60

# Optional timeframe-specific lifecycle overrides (fallback to global values
# above). Use these to separate scalp/intraday/swing behavior.
SIGNALS_SCALP_MIN_HOLD_SECONDS=90
SIGNALS_INTRADAY_MIN_HOLD_SECONDS=90
SIGNALS_SWING_MIN_HOLD_SECONDS=90
SIGNALS_SCALP_TIME_STOP_MINUTES=60
SIGNALS_INTRADAY_TIME_STOP_MINUTES=60
SIGNALS_SWING_TIME_STOP_MINUTES=60
SIGNALS_SCALP_STOP_LOSS_PCT=-0.25
SIGNALS_INTRADAY_STOP_LOSS_PCT=-0.25
SIGNALS_SWING_STOP_LOSS_PCT=-0.25
SIGNALS_SCALP_TARGET_PCT=0.50
SIGNALS_INTRADAY_TARGET_PCT=0.50
SIGNALS_SWING_TARGET_PCT=0.50

# Entry dedupe + reconcile writer lock controls.
# SIGNALS_ENTRY_DEDUPE_WINDOW_SECONDS blocks duplicate opens of the same
# structure/strike/expiry/direction inside this window.
# SIGNALS_RECONCILE_LOCK_ENABLED enables per-underlying advisory xact lock
# so only one writer reconcile cycle mutates positions at a time.
SIGNALS_ENTRY_DEDUPE_WINDOW_SECONDS=60
SIGNALS_RECONCILE_LOCK_ENABLED=true

# Kelly damping fraction (multiplier on the raw kelly).  0.50 = half-Kelly.
# Was hard-coded at 0.25 (quarter-Kelly), which combined with conviction
# scaling and tier % budgets produced microscopic position sizes.
SIGNALS_KELLY_FRACTION=0.50

# Regime filter (time-of-day + event windows).  Suppresses *new* entries
# during low-edge windows; same-direction holds and stops are unaffected.
# Lunch chop window is skipped unless conviction clears the override floor
# (catches trend-day breakouts that happen midday).
# Late-close lockdown allows only eod_pressure-driven entries.
# SIGNALS_EVENT_CALENDAR is comma-separated ISO ET timestamps for scheduled
# macro releases; a buffer of SIGNALS_EVENT_BUFFER_MINUTES on each side is
# muted.  Example: "2026-05-07T08:30,2026-05-21T14:00".
SIGNALS_TIME_FILTER_ENABLED=true
SIGNALS_LUNCH_START_ET=11:30
SIGNALS_LUNCH_END_ET=13:30
SIGNALS_LUNCH_MSI_OVERRIDE=0.75
SIGNALS_LATE_CLOSE_LOCKDOWN_MINUTES=10
SIGNALS_EVENT_BUFFER_MINUTES=15
SIGNALS_EVENT_CALENDAR=

# Require independent confirmation before opening on a single advanced signal.
# Confirmations: another triggered advanced signal, a basic signal above the
# basic cutoff, or MSI conviction above the MSI cutoff (all same direction).
SIGNALS_ADVANCED_REQUIRE_CONFIRMATION=true
SIGNALS_ADVANCED_MIN_BASIC_CONFIRM=0.30
SIGNALS_ADVANCED_MIN_MSI_CONFIRM=0.50

# Adaptive expiry selection: in the first N minutes after the open, the
# optimizer is forced to dte_min=1 instead of 0DTE (overnight risk-premium
# repricing dominates pricing during this window). Set to 0 to disable.
SIGNALS_NO_0DTE_MORNING_MINUTES=90

# Inflection-point sizing boost: when an entry is sourced from a directional-
# expansion advanced signal (range_break_imminence, squeeze_setup), scale
# contracts by SIGNALS_BREAKOUT_SIZE_MULTIPLIER and widen the take-profit
# target to SIGNALS_BREAKOUT_TARGET_PCT (overrides SIGNALS_TARGET_PCT for
# this trade only). The eligible-source list is comma-separated.
SIGNALS_BREAKOUT_SIZE_MULTIPLIER=1.50
SIGNALS_BREAKOUT_TARGET_PCT=1.00
SIGNALS_BREAKOUT_SIGNAL_SOURCES=range_break_imminence,squeeze_setup

# Reject option_chains quote rows older than this when marking an open trade
# for stop/take-profit evaluation. Without this floor a quote-ingest stall
# (or the first cycle after a weekend/holiday) would price the position
# against a multi-day-stale mark and could fire a fictitious stop fill.
# Set to 0 to disable the check (NOT recommended in live trading).
SIGNALS_OPTION_QUOTE_MAX_AGE_SECONDS=900

# Drawdown-aware sizing (rolling-PnL circuit breaker).  After every cycle
# the engine sums realized PnL of the last N closed trades for the symbol.
# When that sum drops below -trigger_pct × portfolio, new entries are sized
# at the multiplier until the rolling sum recovers.  Defaults: lookback=20
# trades, trigger=2% of portfolio, multiplier=0.50 (half size).
SIGNALS_DRAWDOWN_AWARE_SIZING_ENABLED=true
SIGNALS_DRAWDOWN_LOOKBACK_TRADES=20
SIGNALS_DRAWDOWN_TRIGGER_PCT=0.02
SIGNALS_DRAWDOWN_SIZE_MULTIPLIER=0.50

# -----------------------------------------------------------------------------
# Vol-adaptive component thresholds (Phase 2.2)
# -----------------------------------------------------------------------------
# Several MSI components hard-coded percentage thresholds (e.g. flip_distance
# saturated at 2%, price_vs_max_gamma at 1%) that treat calm and volatile
# regimes identically.  When SIGNAL_VOL_ADAPTIVE_ENABLED=true (default) these
# thresholds become k × realized_sigma over a rolling 1-minute lookback,
# bounded by per-component min/max floors with a fallback to the original
# fixed % when recent_closes is too sparse to compute sigma reliably.
SIGNAL_VOL_ADAPTIVE_ENABLED=true
SIGNAL_VOL_LOOKBACK_BARS=30
SIGNAL_VOL_MIN_BARS=10

# flip_distance: k=10 with typical 0.15%/min sigma yields ~1.5% saturation,
# close to the original fixed 2%.  Bounds clamp the saturation to a sane
# intraday range regardless of vol regime.
SIGNAL_FLIP_DISTANCE_K_SIGMA=10.0
SIGNAL_FLIP_DISTANCE_FALLBACK_PCT=0.02
SIGNAL_FLIP_DISTANCE_MIN_PCT=0.005
SIGNAL_FLIP_DISTANCE_MAX_PCT=0.05

# price_vs_max_gamma: pinning is a tighter regime; k=6 keeps saturation
# closer to the strike than flip_distance.
SIGNAL_PRICE_VS_MAX_GAMMA_K_SIGMA=6.0
SIGNAL_PRICE_VS_MAX_GAMMA_FALLBACK_PCT=0.01
SIGNAL_PRICE_VS_MAX_GAMMA_MIN_PCT=0.003
SIGNAL_PRICE_VS_MAX_GAMMA_MAX_PCT=0.03

# -----------------------------------------------------------------------------
# Normalizer cache refresh tool (src.tools.normalizer_cache_refresh)
# -----------------------------------------------------------------------------
# dealer_vanna_exposure / dealer_charm_exposure were put on a
# dimensionally-honest dollar basis at the 2026-05-15 deploy (vanna ×0.01).
# Rows written before the deploy are ~100x too large; sampling them would
# derive a vanna normalizer ~100x too big and silently flatten the
# vanna/charm signal.  The refresh tool floors the dealer vanna/charm
# sample queries at this instant ("AND timestamp >= <cutoff>") so a
# refresh can never sample pre-rescale magnitudes.  A bare date is read
# in US/Eastern; a value with an offset is honored as-is.  If the
# post-cutoff sample is below the tool's MIN_SAMPLES the field is left
# unset (the signal keeps its corrected fallback constant) rather than
# written at low confidence.  A malformed value makes the tool refuse to
# run (fail-closed) rather than silently disabling the floor.
NORMALIZER_DEPLOY_CUTOFF=2026-05-16

# vanna_charm_flow no-cache / cold-start fallback normalizers (used only
# for a symbol with no component_normalizer_cache row yet; the per-symbol
# cache p95 is authoritative once present).  Calibrated to the SPY
# post-rescale SUM-across-the-book p95 from the 2026-05-19 cutoff-guarded
# refresh (vanna p95≈1.41e8, charm p95≈9.35e9), rounded up so a typical
# book lands mid-range.  The prior 1e7/1e9 predated post-rescale live
# data and saturated the cold-cache path to ±1.
SIGNAL_VANNA_NORM=1.5e8
SIGNAL_CHARM_NORM=1.0e10

# Read-only gamma-flip threshold re-validation tool
# (src.tools.gamma_flip_revalidation / make gamma-flip-revalidate).
# Mirrors portfolio_engine's inline "flip not near" band so the analysis
# scores the same gate the live code uses.  Analysis-only; changing it
# does not change live behavior.
GAMMA_FLIP_NOT_NEAR_PCT=0.006

# Optional: ISO date/datetime (US/Eastern when offset-less) marking when
# the gamma-flip calc last STABILIZED in production (the flip kept
# changing after the deploy: 7106711 -> 1731efc spot-shift -> 62c70df
# DTE-weighted).  When set, the re-validation's POST era is restricted to
# rows at/after this instant (one settled definition) and the
# in-between rows are reported as an excluded transitional bucket.  Blank
# = single split at the deploy cutoff.  Analysis-only.
# GAMMA_FLIP_STABLE_SINCE=2026-05-19T12:00:00-04:00

# -----------------------------------------------------------------------------
# Look-ahead audit: GEX stale-buffer (Phase 2.5)
# -----------------------------------------------------------------------------
# The analytics engine aggregates option quotes into 1-minute buckets stamped
# with the bucket start time, so a gex_summary row at 14:00 was actually
# computed from quotes arriving up to 14:00:59 — a bounded look-ahead window
# for backtests replaying at sub-minute resolution.  Live trading is
# unaffected.  Default 0 (no buffer) preserves live behavior; set to the
# bucket width (typically 60) when running historical replay.
SIGNALS_GEX_STALE_BUFFER_SECONDS=0

# Dealer Regime hard-entry gates.
# Calls require DRS above threshold while holding above gamma flip.
# Puts require a fresh break below gamma flip and DRS below threshold.
SIGNALS_DRS_HARD_GATES_ENABLED=true
SIGNALS_DRS_CALL_ENTRY_MIN=0.40
SIGNALS_DRS_PUT_ENTRY_MAX=0.20

# Emit verbose position optimizer diagnostics in logs.
# Default: false
POSITION_OPTIMIZER_VERBOSE_DIAGNOSTICS=false

# Number of expiration dates to track.
# When OPTION_ROOT_ALIASES maps the underlying to a weekly-only root (e.g. SPXW),
# expirations are fetched for that root so only weekly dates are returned.
# Default: 3
INGEST_EXPIRATIONS=3

# Extra EXPIRATIONS pulled from the monthly chain (mapped per-symbol via
# INGEST_MONTHLY_UNDERLYING_ALIASES). These layer ON TOP OF the weekly window
# above. Use for index underlyings whose AM-settled monthlies live under a
# different chain root than the weeklies and would otherwise never be ingested.
# Default: 0 (off)
# Example (paired with SYMBOL_ALIASES=SPX=$SPXW.X, OPTION_ROOT_ALIASES=$SPXW.X=SPXW,$SPX.X=SPX,
# INGEST_MONTHLY_UNDERLYING_ALIASES=SPX=$SPX.X):
#   INGEST_MONTHLY_EXPIRATIONS=3
# yields: 3 weekly SPXW expirations + 3 monthly AM-settled SPX expirations,
# all keyed under option_chains.underlying='SPX'.
INGEST_MONTHLY_EXPIRATIONS=0

# Strike-selection band, in percent of the underlying spot price.
# All strikes within ±INGEST_STRIKE_PCT_RANGE% of spot are eligible per expiration.
# e.g. 3.0 with spot=$500 -> [$485, $515].
# The window re-centers automatically every STRIKE_RECALC_INTERVAL iterations.
# Default: 3.0
INGEST_STRIKE_PCT_RANGE=3.0

# Hard cap on the total number of strikes ingested per expiration.
# If the ±INGEST_STRIKE_PCT_RANGE% band contains more strikes than this,
# the list is trimmed from the furthest-from-spot strikes inward until
# the count fits. Acts as a safety ceiling against the TradeStation per-day
# API-call cap on dense chains (e.g. SPX $5 strikes).
# Default: 40
INGEST_STRIKE_COUNT_MAX=40

# Maximum wait between stream drain cycles (seconds).
# The main loop wakes immediately when a stream accumulator receives data;
# these values only cap the longest it will block when streams are quiet.
# Default: 5 / 30 / 300
MARKET_HOURS_POLL_INTERVAL=5
EXTENDED_HOURS_POLL_INTERVAL=30
CLOSED_HOURS_POLL_INTERVAL=300

# How often to re-center the tracked strike window around the latest price.
# One iteration = one poll cycle (MARKET_HOURS_POLL_INTERVAL seconds during market hours).
# At the default 5s poll, STRIKE_RECALC_INTERVAL=12 recalibrates every ~1 minute.
# Default: 12
STRIKE_RECALC_INTERVAL=12

# How often to cleanup expired strikes (iterations)
# Default: 100
STRIKE_CLEANUP_INTERVAL=100

# Session template for streaming data
# Options: Default (9:30-16:00), USEQPre (4:00-9:30), USEQ24Hour (4:00-20:00)
SESSION_TEMPLATE=Default

# Alert thresholds for option quote field coverage quality checks.
# Coverage is computed each poll iteration as:
#   non-zero field count / total option quotes processed
# Defaults: 35%
OPTION_OI_COVERAGE_ALERT_THRESHOLD=0.35
OPTION_VOLUME_COVERAGE_ALERT_THRESHOLD=0.35

# Re-seed option state from REST when strike recalibration restarts streams.
# Default: false (startup still seeds from REST).
OPTION_REST_SEED_ON_RECALC=false

# Minimum seconds between flow cache refreshes in API/analytics paths.
# Default: 15
FLOW_CACHE_REFRESH_MIN_SECONDS=15

# Enable/disable analytics-triggered flow cache refreshes.
# Default: true
ANALYTICS_FLOW_CACHE_REFRESH_ENABLED=true

# Analytics snapshot underlying-staleness gate (in-session only). If the latest
# underlying quote is older than this during the symbol's active session, the
# snapshot is treated as stale and the engine holds rather than publishing on a
# frozen underlying. Off-session the gate steps aside so the API serves the
# frozen end-of-session snapshot. Default: 900 (15 min).
ANALYTICS_MAX_UNDERLYING_STALENESS_SECONDS=900

# Floor (minutes) on time-to-expiry used in Greeks/GEX pricing. Black-Scholes
# gamma scales ~1/sqrt(T), so a near-zero T lets an about-to-expire contract
# dominate GEX/walls; clamping T to this floor kills that blow-up.
# Default: 30 (clamped to a hard minimum of 0.5).
ANALYTICS_MIN_TTE_MINUTES=30

# In-process endpoint cache TTLs (seconds) for API read paths.
# Lower values reduce staleness but increase DB load.
LATEST_QUOTE_CACHE_TTL_SECONDS=1.5
LATEST_GEX_SUMMARY_CACHE_TTL_SECONDS=1.5
ANALYTICS_CACHE_TTL_SECONDS=5.0
FLOW_ENDPOINT_CACHE_TTL_SECONDS=3.0
# Dedicated TTL for /api/flow/series only (by-contract/contracts keep the
# shared value above). Its unfiltered read is a flow_series_5min snapshot
# the Analytics Engine rewrites only ~once per cycle (~60s), so a short
# TTL just forces redundant reads; the live tail is polled via intervals=N
# which bypasses this cache, so a longer value never stales the updating
# number. Also amortises the heavier strike/expiration-filtered CTE.
# Set <= 0 to disable /api/flow/series endpoint caching.
FLOW_SERIES_ENDPOINT_CACHE_TTL_SECONDS=30.0

# /api/gex/heatmap returns strikes within spot ± this fraction of spot
# (applies to every underlying). Sized to the chart's max y-axis margin
# (0.02 base x 4.0 max zoom-out = 0.08) so the colored surface fills the
# price-cropped view at any price level. Bounded to [0.005, 0.5].
GEX_HEATMAP_STRIKE_BAND_PCT=0.08

# Gamma flip / net-GEX-at-spot come from the SpotGamma-style spot-shift
# dealer gamma-exposure profile: option gammas are re-priced via
# Black-Scholes across a grid of hypothetical spots spanning spot ±
# SPAN_PCT, stepped by STEP_PCT of spot.  The flip is the zero crossing
# of that profile.
#
# Resolution is ADAPTIVE BRACKET-AND-VERIFY: the span ladder is walked
# in ascending order (GAMMA_PROFILE_SPAN_PCT first, then each value in
# GAMMA_PROFILE_EXPANSION_RUNGS), and the first rung yielding a
# STRUCTURAL INTERIOR crossing is accepted.  When no rung qualifies,
# the flip is persisted NULL+WARN — the honest "actionable flip is
# beyond ±MAX% from spot, or the chain is degraded" signal, not a
# fabricated edge value or a noise-floor sign change.  The two gates:
#
#   * INTERIOR — the linearly-interpolated crossing sits at least
#     GAMMA_PROFILE_INTERIOR_MARGIN of the grid span away from each
#     edge.  Forces the resolver to expand the grid rather than accept
#     a brittle near-edge value (the 2026-05-19 QQQ pathology: $839 /
#     $802 flips resolved at the ±20% grid boundary).
#   * STRUCTURAL — the peak |profile| within
#     ±GAMMA_PROFILE_STRUCTURAL_WINDOW_PCT × candidate of the crossing
#     is at least GAMMA_PROFILE_STRUCTURAL_MIN_FRAC × (global peak
#     |profile|).  Rejects sign changes in the noise floor (every
#     contract's gamma decayed near zero — IV-spike / extended-hours
#     artifact).
#
# Bounds: SPAN [0.02, 1.0], STEP [0.0001, 0.05], INTERIOR_MARGIN
# [0.0, 0.49], STRUCTURAL_MIN_FRAC [0.0, 1.0], STRUCTURAL_WINDOW_PCT
# [0.001, 0.10].  EXPANSION_RUNGS: comma-separated ascending fractions
# of spot, each in [0.02, 1.0]; rungs ≤ SPAN_PCT are dropped silently.
GAMMA_PROFILE_SPAN_PCT=0.20
GAMMA_PROFILE_EXPANSION_RUNGS=0.35,0.50
GAMMA_PROFILE_INTERIOR_MARGIN=0.10
GAMMA_PROFILE_STRUCTURAL_MIN_FRAC=0.02
GAMMA_PROFILE_STRUCTURAL_WINDOW_PCT=0.01
GAMMA_PROFILE_STEP_PCT=0.0025

# The gamma flip is a multi-day regime level, but a same-day 0DTE wall
# carries a colossal re-greeked BS-gamma spike (ATM gamma ~ 1/sqrt(T))
# that can pin it to an irrelevant same-day strike. When enabled, each
# contract's profile contribution is scaled by a linear horizon-occupancy
# ramp min(1, DTE / DTE_REF_DAYS) -- the fraction of the reference horizon
# the contract survives -- so same-day expiries are down-weighted out of
# contention while contracts at/beyond the reference are unaffected.
# Bounds: DTE_REF_DAYS [0.5, 60.0].
GAMMA_PROFILE_DTE_WEIGHTING=true
GAMMA_PROFILE_DTE_REF_DAYS=5.0

# DTE weight curve shape: linear | sqrt | exp.
#   linear (default): w = min(1, DTE/ref).  Horizon-occupancy ramp, hard
#       saturation at DTE=ref.  Cleanest semantics, one knob.
#   sqrt:   w = sqrt(min(1, DTE/ref)).  More aggressive on near-dated
#       (1DTE under sqrt R=2 is 0.71 vs linear's 0.50); per-OI contribution
#       is constant for DTE < ref.  Hard saturation at DTE=ref.
#   exp:    w = 1 - exp(-DTE/ref).  Smooth — no saturation corner;
#       reaches ~0.63 at DTE=ref and ~0.95 at DTE=3*ref.
# All three suppress the BS 1/√T near-expiry gamma spike.  Invalid values
# fall back to linear with a WARN.
GAMMA_PROFILE_DTE_WEIGHT_SHAPE=linear

# Max-pain daily snapshot refresh (scheduled, off-process).
#
# Max pain is a daily figure — open interest only changes at settlement.
# The recompute is a heavy multi-CTE scan over option_chains.  It used to
# run every 5 min in-process and inline on requests, which scanned
# option_chains during the cash session and starved the Analytics engine.
# It now runs ONCE per day, pre-market, via
# zerogex-oa-max-pain-refresh.timer -> src.tools.max_pain_refresh
# (install: `make max-pain-refresh-install`).  /api/max-pain/current is a
# pure cache read of the snapshot tables.
#
# These configure that scheduled job (env var names kept stable so
# existing operator .env files don't need editing).  There is no longer
# an ENABLED flag or INTERVAL — the systemd timer owns scheduling.
MAX_PAIN_BACKGROUND_REFRESH_SYMBOLS=SPY,SPX,QQQ
MAX_PAIN_BACKGROUND_REFRESH_STRIKE_LIMIT=500
# Per-statement timeout for the recompute (SET LOCAL + asyncpg timeout=).
# Runs off-hours with the box idle, so a long budget no longer contends
# with anything; 300s covers SPX after the cash session.
MAX_PAIN_BACKGROUND_REFRESH_STATEMENT_TIMEOUT_MS=300000
# In-process cache TTL (seconds) for the /api/max-pain/current response.
# The snapshot changes at most once a day, so this just spares redundant
# identical DB reads. Set <= 0 to disable endpoint caching.
MAX_PAIN_CURRENT_CACHE_TTL_SECONDS=120.0

# If true, flow cache refresh writes only canonical flow_contract_facts outputs.
# If false, legacy flow cache tables are also refreshed.
# Default: true
FLOW_CANONICAL_ONLY=true

# Enable parity signature logging for ingestion payloads written to:
# - symbols
# - underlying_quotes
# - option_chains
# Emits [PARITY] logs with deterministic payload signature + canonical JSON.
# Default: false
INGEST_PARITY_GUARD_ENABLED=false

# NYSE observed market holidays — comma-separated YYYY-MM-DD dates.
# Used by the /api/market/quote "session" field to determine whether the market
# is open, in pre/after-hours, or closed.  Update this list each year.
NYSE_HOLIDAYS=2024-01-01,2024-01-15,2024-02-19,2024-03-29,2024-05-27,2024-06-19,2024-07-04,2024-09-02,2024-11-28,2024-12-25,2025-01-01,2025-01-09,2025-01-20,2025-02-17,2025-04-18,2025-05-26,2025-06-19,2025-07-04,2025-09-01,2025-11-27,2025-12-25,2026-01-01,2026-01-19,2026-02-16,2026-04-03,2026-05-25,2026-06-19,2026-07-03,2026-09-07,2026-11-26,2026-12-25,2027-01-01,2027-01-18,2027-02-15,2027-03-26,2027-05-31,2027-06-18,2027-07-05,2027-09-06,2027-11-25,2027-12-24

# -----------------------------------------------------------------------------
# Data Aggregation Configuration
# -----------------------------------------------------------------------------
# Time bucket size for aggregation (seconds)
# Default: 60 (1 minute)
AGGREGATION_BUCKET_SECONDS=60

# Maximum buffer size before forcing flush
# Default: 1000
MAX_BUFFER_SIZE=1000

# Buffer flush interval (seconds)
# Flush buffers if no data received for this duration
# Default: 60
BUFFER_FLUSH_INTERVAL=60

# Minimum seconds between in-minute option upserts per contract/bucket.
# Helps reduce hot-row UPDATE churn.
# Default: 5
OPTION_BUCKET_WRITE_MIN_SECONDS=5


# -----------------------------------------------------------------------------
# Analytics Engine Configuration
# -----------------------------------------------------------------------------
# Underlying symbol to analyze
ANALYTICS_UNDERLYING=SPY

# Multi-symbol analytics (comma-separated, overrides ANALYTICS_UNDERLYING when set)
# Example: ANALYTICS_UNDERLYINGS=SPY,SPX
ANALYTICS_UNDERLYINGS=

# Calculation interval (seconds)
ANALYTICS_INTERVAL=60

# Lookback window (hours) used to build a per-contract latest snapshot for GEX.
# Anchored to the most recent option_chains row, not wall-clock NOW().  Sized
# for steady-state cycles during/around RTH where every active contract is
# requoted within minutes; a small window keeps the per-cycle Index Only Scan
# tuple-walk bounded so snapshot runs in ~1 sec even under concurrent VACUUM /
# autovacuum IO.  The first cycle after process start uses a separate, wider
# ANALYTICS_SNAPSHOT_COLD_START_LOOKBACK_HOURS so Monday-morning warm-ups still
# reach the prior session's closing quotes.
# Accepts fractional hours (e.g. 0.5 = 30 min, 0.25 = 15 min) for operators
# on cold-storage buffer pools who need to shrink the working set without a
# schema change.  Floored at 1/12 h (5 min) to keep recently-quoted contracts
# from silently dropping out of the snapshot.
# Default: 2
ANALYTICS_SNAPSHOT_LOOKBACK_HOURS=2

# Lookback window (hours) used by the FIRST snapshot of each worker process
# after startup -- but ONLY when the newest option_chains row is itself
# stale (older than ANALYTICS_SNAPSHOT_LOOKBACK_HOURS).  Wide enough to
# reach the prior trading session's closing quotes across a long-weekend
# gap.  A mid-session restart with live ingestion sees a fresh newest row
# and skips straight to the steady-state window even on cycle 1 (no slow
# first cycle).  The "consumed" flag flips after one cycle regardless of
# outcome, so a slow/failed cold-start can never loop.
# Default: 96
ANALYTICS_SNAPSHOT_COLD_START_LOOKBACK_HOURS=96

# Dedicated per-statement timeout (ms) applied via SET LOCAL to the
# wide cold-start snapshot scan AND to the FIRST CYCLE of the cheap
# steady-state path (so a mid-session restart with live ingestion -- where
# data is fresh and the wide cold-start window is skipped -- still gets a
# generous budget while the buffer pool warms up).  The pool-wide
# DB_STATEMENT_TIMEOUT_MS (default 90000) is sized for sub-second API
# queries and can kill the legitimately-slow first-cycle snapshot on a
# cold buffer pool.  This higher ceiling is scoped to that single query
# and reverts on commit.  If the cold-start window scan fails (timeout or
# otherwise) the engine rolls back and retries the SAME cycle with the
# steady-state window under this same budget, so the first cycle yields
# a narrower-but-non-empty result instead of a hard error.  Set 0 to
# disable the override (use the pool default).  Raise (e.g. 240000 /
# 300000) if cycle 1 still times out -- usually a sign of cold-storage
# disk latency that needs more I/O budget to warm the pool.
# Default: 180000 (3 minutes)
ANALYTICS_SNAPSHOT_COLD_START_STATEMENT_TIMEOUT_MS=180000

# Dedicated per-statement timeout (ms) applied via SET LOCAL to the
# STEADY-STATE snapshot query (the per-cycle 2h-lookback DISTINCT-ON
# scan), for cycles 2+ only.  Normally finishes in seconds but can spike
# past the pool-wide DB_STATEMENT_TIMEOUT_MS (default 90s) during
# autovacuum + concurrent ingestion bursts -- and when that happens every
# cycle gets killed at 90s, the cycle exits at the "if not snapshot"
# guard, and the next cycle starts immediately into another 90s kill (no
# progress; the downstream flow_series_5min snapshot never refreshes, so
# the API emits "flow_series_5min shortfall" warnings).  Set to a value
# greater than DB_STATEMENT_TIMEOUT_MS (e.g. 150000) to relax just this
# query without raising the pool-wide ceiling.  Default 0 = use the pool
# default (no behavior change).
#
# NOTE on cycle 1: the FIRST cycle of each worker process always uses
# ANALYTICS_SNAPSHOT_COLD_START_STATEMENT_TIMEOUT_MS regardless of which
# lookback window was chosen, because the buffer pool is cold from the
# restart in either case.  This value applies only from cycle 2 onward,
# once the pool has warmed up.
# Default: 0 (use pool ceiling)
ANALYTICS_SNAPSHOT_STATEMENT_TIMEOUT_MS=0

# Per-worker startup-stagger window (seconds) for multi-symbol deployments.
# All worker processes fork at the same wall-clock instant and then enter
# a sleep(interval) cycle; without an offset their per-cycle _get_snapshot
# calls stay locked in-phase forever after a restart and pile onto the
# same buffer-pool window, producing DataFileRead contention.  Offsetting
# worker i by i * (interval / N) seconds spreads the snapshot queries
# across the cycle so only one is "live" against the DB at any instant.
#   * "auto" (default): even spread = interval / N seconds between workers.
#   * "0" / "off" / "false" / "disabled" / "": no stagger (legacy behavior).
#   * any non-negative number: explicit per-worker delay in seconds.
# Single-symbol deployments ignore this setting (nothing to stagger).
# Default: auto
ANALYTICS_WORKER_STAGGER_SECONDS=auto

# Read latest-per-contract option data from the maintained
# `option_chains_latest` cache table instead of running DISTINCT ON
# over `option_chains` history.  The cache is one row per option_symbol,
# kept current by the ingestion writer's dual-UPSERT, so the snapshot
# read becomes a single indexed lookup rather than a sort over the
# intraday rolling window.  This is the structural fix for the
# 2026-05-26 production incident; see setup/database/schema.sql for
# the activation sequence.
#
# SAFE TO FLIP MID-SESSION: if the cache returns 0 rows for a cycle
# (warm-up window after the flag flip, ingestion outage, off-hours
# pause with stale cache), the engine logs a warning and falls back to
# the legacy DISTINCT ON path for that cycle.  Worst case is one slow
# cycle, not an empty snapshot.
#
# Default OFF so deploying the code alone is a no-op; operators flip
# this AFTER applying the schema migration and waiting for the cache
# to populate (5-30 min during RTH).
# Default: false
ANALYTICS_USE_LATEST_CACHE=false

# Off-hours mode.  When true the analytics engine keeps cycling on
# weekends / NYSE holidays instead of sleeping until the next session.
# The snapshot is anchored to the latest option_chains row (not
# wall-clock NOW()), so an off-hours cycle recomputes against the most
# recent available data (e.g. Friday's close on a Saturday) rather than
# reporting nothing.  Set false for the legacy "pause until next 24x5
# window" behavior.
# Default: true
ANALYTICS_OFF_HOURS_ENABLED=true

# Cycle interval (seconds) used while off-hours (see ANALYTICS_OFF_HOURS_
# ENABLED).  Longer than the steady-state interval since the underlying
# data is static until the next session, so frequent recomputes add no
# information.  Floored at ANALYTICS_INTERVAL (an off-hours cycle can
# never run more often than a steady-state one).
# Default: 300 (5 minutes)
ANALYTICS_OFF_HOURS_INTERVAL_SECONDS=300

# Freshness gate (seconds) for contract snapshots used in analytics.
# Contracts older than this are excluded from the per-contract latest snapshot.
# Default: 180
ANALYTICS_SNAPSHOT_FRESHNESS_SECONDS=180

# Alert threshold for low OI coverage in analytics snapshots.
# Coverage = contracts with OI>0 / total contracts in snapshot.
# Default: 35%
ANALYTICS_MIN_OI_COVERAGE_PCT_ALERT=0.35

# -----------------------------------------------------------------------------
# Signal Engine Thresholds / Auto-tuning
# -----------------------------------------------------------------------------
# Signal Engine cycle interval (seconds)
# Minimum enforced by code: 1
SIGNALS_INTERVAL=1

SIGNAL_SMART_MONEY_DOMINANCE_RATIO=1.2
SIGNAL_VWAP_DEV_BULL_THRESHOLD_PCT=0.2
SIGNAL_VWAP_DEV_BEAR_THRESHOLD_PCT=-0.2
SIGNAL_PCR_BULLISH_THRESHOLD=0.7
SIGNAL_PCR_BEARISH_THRESHOLD=1.3
SIGNAL_AUTO_TUNE_ENABLED=true
SIGNAL_AUTO_TUNE_LOOKBACK_DAYS=20
SIGNAL_AUTO_TUNE_MIN_SAMPLES=250

# Include IV-rank percentile as an additional signal feature.  The query
# is opportunistic — it falls back gracefully when the 30-day daily IV
# history is missing — so it ships enabled.  Disable only if option_chains
# depth becomes a perf concern.  When disabled, ``tension.iv_rank`` is
# permanently None and the vol-tension pillar in market_pressure is
# structurally capped at half magnitude.
# Default: true
SIGNAL_IV_RANK_ENABLED=true

# NOTE: SIGNAL_IV_RANK_TIMEOUT_MS was removed once iv_rank was migrated
# from an in-engine 30-day option_chains aggregation to a trivial read
# from the daily_atm_iv aggregate table (written by the analytics
# engine).  The new query reads ~30 rows in <1ms and doesn't need a
# dedicated timeout override.

# Optional SMS notifications for strong signal hits (Twilio)
# Set SIGNAL_SMS_ENABLED=true to enable.
SIGNAL_SMS_ENABLED=false
SIGNAL_SMS_PROVIDER=twilio
SIGNAL_SMS_TO_NUMBERS=+15551234567,+15557654321
SIGNAL_SMS_FROM_NUMBER=+15550001111
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Minimum normalized score (0..1) required before texting
SIGNAL_SMS_MIN_NORMALIZED_SCORE=0.67
# Minimum strength bucket: low | medium | high
SIGNAL_SMS_MIN_STRENGTH=high
# Timeframes that can trigger SMS (comma-separated)
SIGNAL_SMS_TIMEFRAMES=intraday,swing
# Dedup/cooldown window to avoid spam for repeated same-direction hits
SIGNAL_SMS_COOLDOWN_SECONDS=900

# -----------------------------------------------------------------------------
# Volatility Expansion Thresholds / Auto-tuning
# -----------------------------------------------------------------------------
VOL_SMART_MONEY_DOMINANCE_RATIO=1.2
# Gamma-regime cutoffs in the industry-standard "$ gamma per 1% move" scale
# (γ × OI × 100 × S² × 0.01).  Pre-fix values (-5e9 / -3e9) were on the
# share-equivalent scale and have been multiplied by ≈7 for SPY-magnitude
# underlyings.  Override for higher-priced names.
VOL_GAMMA_DEEP_NEGATIVE=-35000000000
VOL_GAMMA_NEGATIVE=-21000000000
VOL_GAMMA_FLIP_NEAR_PCT=0.003
VOL_PCR_HIGH=1.8
VOL_PCR_LOW=0.4
VOL_AUTO_TUNE_ENABLED=true
VOL_AUTO_TUNE_LOOKBACK_DAYS=30
VOL_AUTO_TUNE_MIN_SAMPLES=250

# -----------------------------------------------------------------------------
# Greeks & IV Calculation Configuration
# -----------------------------------------------------------------------------
# Enable real-time Greeks calculations
# Default: true
GREEKS_ENABLED=true

# Enable real-time IV calculation from option prices
# If false, will only use IV provided by API or default IV
# Default: true
IV_CALCULATION_ENABLED=true

# IV Solver Configuration
IV_MAX_ITERATIONS=100
IV_TOLERANCE=0.00001
IV_MIN=0.01
IV_MAX=5.0

# Risk-free rate for Greeks calculation (annual rate)
# Example: 0.05 = 5% annual risk-free rate
# Default: 0.05
RISK_FREE_RATE=0.05

# Default implied volatility if not available from API or calculation
# Example: 0.20 = 20% volatility
# Default: 0.20
IMPLIED_VOLATILITY_DEFAULT=0.20

# Continuous dividend yield (q) for the Black-Scholes-Merton Greeks/IV model.
# Default 0.0 reproduces the prior dividend-free model exactly (deploying is a
# no-op). Set it to remove the systematic call/put-delta and solved-IV bias on
# dividend-paying underlyings. Applied to any symbol NOT listed in
# DIVIDEND_YIELD_BY_SYMBOL below. Range [0, 0.2].
# Default: 0.0
DIVIDEND_YIELD=0.0

# Per-symbol dividend-yield overrides (JSON), keyed by CANONICAL symbol
# (e.g. "SPY", "SPX" — what the engine stores, NOT "$SPX.X"). Any symbol not in
# the map falls back to DIVIDEND_YIELD above. Values clamp to [0, 0.2].
# NOTE: $SPX.X is a cash index that pays no dividend itself, but its BSM forward
# should still discount the constituents' yield (~1.5%), so a non-zero "SPX" q
# is correct. Resolved once at worker startup — change requires a service
# restart to take effect.
# Default: unset (empty map)
# DIVIDEND_YIELD_BY_SYMBOL={"SPY": 0.013, "QQQ": 0.006, "IWM": 0.011, "SPX": 0.015}

# -----------------------------------------------------------------------------
# Yesterday's Scorecard Auto-Tweet (zerogex-oa-scorecard-tweet.timer)
# -----------------------------------------------------------------------------
# The 4:15 PM ET cron job that posts a one-line daily recap of Action Cards
# emitted and per-signal flip P&L to the brand X account.
#
# Unset: the job runs in DRY-RUN — it computes the scorecard and logs the
#        tweet copy to journalctl so operators can review wording without
#        anything going public.
# Set:   the job posts to https://api.x.com/2/tweets with this bearer token.
#        Posting ALSO requires the --post flag baked into the systemd unit
#        — defense in depth so a half-configured rollout can't accidentally
#        start tweeting.
# Default: unset
# X_BOT_BEARER_TOKEN=
#
# Permalink host used in the tweet body. Optional override; defaults to
# https://zerogex.io in the job code.
# Default: unset (uses https://zerogex.io)
# ZEROGEX_SITE_URL=https://zerogex.io

# -----------------------------------------------------------------------------
# Example Production Configuration
# -----------------------------------------------------------------------------
# For production deployment, you might use:
#
# LOG_LEVEL=INFO

# API_RETRY_ATTEMPTS=5
# MARKET_HOURS_POLL_INTERVAL=1
# EXTENDED_HOURS_POLL_INTERVAL=10
# GREEKS_ENABLED=true
# DB_PASSWORD_PROVIDER=aws_secrets_manager
#

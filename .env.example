###########################################################################################################
# TradeStation API Parameters
# Documentation: https://api.tradestation.com/docs/fundamentals/authentication/auth-overview/
#
# TRADESTATION_CLIENT_ID     - "client ID" or "API key" provided by TradeStation
# TRADESTATION_CLIENT_SECRET - secret for the API key provided by TradeStation - can be rotated by
#                              contacting Client Service
# TRADESTATION_REFRESH_TOKEN - refresh token granted during the authorization code flow (see
#                              https://api.tradestation.com/docs/fundamentals/authentication/refresh-tokens
#                              for complete specifications
#
###########################################################################################################
TRADESTATION_CLIENT_ID=xxxxxxxxxx
TRADESTATION_CLIENT_SECRET=xxxxxxxxxx
TRADESTATION_REFRESH_TOKEN=xxxxxxxxxx

# Use sandbox/simulation environment (true) or production (false)
# Default: false
TRADESTATION_USE_SANDBOX=false

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Market Hours Warnings
# -----------------------------------------------------------------------------
# Show warnings when fetching data while market is closed
# Set to 'false' to suppress warnings globally
# Default: true
TS_WARN_MARKET_HOURS=true

# -----------------------------------------------------------------------------
# TradeStation Client Test Configuration
# -----------------------------------------------------------------------------
# These control the behavior of: python -m src.ingestion.tradestation_client
# Command-line arguments override these settings

# Which test to run: all, quote, bars, stream-bars, options, options-expirations, options-strikes, option-quote, search, market-hours, depth
# Default: all
TS_TEST=all

# Symbol(s) to test with (comma-separated for multiple)
# Default: SPY
# Supports aliases if SYMBOL_ALIASES is configured below (e.g., SPX)
TS_SYMBOL=SPY

# Number of bars to retrieve
# Default: 5
TS_BARS_BACK=5

# Bar interval (1, 5, 15, 60, etc.)
# Default: 1
TS_INTERVAL=1

# Bar time unit: Minute, Daily, Weekly, Monthly
# Default: Daily
TS_UNIT=Daily

# Search query for symbol search test
# Default: Apple
TS_QUERY=Apple

# -----------------------------------------------------------------------------
# Shared Symbol Resolution Configuration (used by ingestion, analytics, and CLI tests)
# -----------------------------------------------------------------------------
# Symbol aliases: human-friendly alias -> TradeStation underlying symbol.
# The alias is stored in the database and used in the API/analytics.
# The resolved TradeStation symbol is used for: underlying bars, option
# expirations, and option strikes lookups.
# Format: ALIAS=TS_SYMBOL,ALIAS2=TS_SYMBOL2
# Example: SYMBOL_ALIASES=SPX=$SPX.X,NDX=$NDX.X
SYMBOL_ALIASES=

# Option-root overrides: TradeStation underlying symbol -> option chain root.
# Used ONLY when constructing option chain symbol strings for get_option_quotes().
# e.g. "$SPX.X=SPXW" means option quotes are fetched as "SPXW 260321C6630",
# but expirations and strikes are still fetched using "$SPX.X".
# Format: TS_SYMBOL=OPTION_ROOT
# Example: OPTION_ROOT_ALIASES=$SPX.X=SPXW
OPTION_ROOT_ALIASES=

# Option roots that only support weekly (Mon/Wed/Fri) expirations.
# When a root is listed here, the expirations returned by get_option_expirations()
# for the underlying are filtered to Mon/Wed/Fri only, because building e.g.
# "SPXW ..." for a non-weekly date would be rejected by the TradeStation API.
# Must match the root(s) you set in OPTION_ROOT_ALIASES.
# Format: OPTION_WEEKLY_ROOTS=SPXW,OTHER_WEEKLY_ROOT
OPTION_WEEKLY_ROOTS=

# -----------------------------------------------------------------------------
# API Request Configuration
# -----------------------------------------------------------------------------
# Timeout for API requests (seconds)
# Default: 30
API_REQUEST_TIMEOUT=30

# Read timeout for long-lived TradeStation stream connections (seconds)
# This should generally be higher than API_REQUEST_TIMEOUT to avoid reconnect churn.
# Default: 300
TS_STREAM_READ_TIMEOUT=300

# Reuse persistent HTTP stream connections for one-line snapshot reads.
# Default: false (recommended) to avoid waiting for the "next" stream event,
# which can introduce ingestion write lag in snapshot-style polling loops.
# Set to true only if you explicitly want long-lived stream reuse behavior.
TS_STREAM_REUSE_CONNECTIONS=false

# Reuse stream/quotes connections by default to reduce reconnect churn and 429s.
# This only applies when TS_STREAM_REUSE_CONNECTIONS is false.
# Default: true
TS_STREAM_REUSE_QUOTES=true

# Number of retry attempts for failed requests
# Default: 3
API_RETRY_ATTEMPTS=3

# Initial delay between retries (seconds)
# Default: 1.0
API_RETRY_DELAY=1.0

# Backoff multiplier for exponential retry delay
# Example: attempt 1 = 1s, attempt 2 = 2s, attempt 3 = 4s
# Default: 2.0
API_RETRY_BACKOFF=2.0

# Batch size for quote requests (max 500 per TradeStation API)
# Default: 100
QUOTE_BATCH_SIZE=100

# Batch size for option quote requests
# Default: 100
OPTION_BATCH_SIZE=100

# Delay between batches of requests (seconds)
# Default: 0.5
DELAY_BETWEEN_BATCHES=0.5

# Delay between processing bars during backfill (seconds)
# Default: 1.0
DELAY_BETWEEN_BARS=1.0

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Database connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zerogex
DB_USER=postgres

# Database password provider: 'pgpass', 'aws_secrets_manager', or 'env'
#
# RECOMMENDED: 'pgpass' (default)
# - Uses ~/.pgpass file (PostgreSQL standard)
# - No password in code or environment variables
# - Secure file permissions (600) enforced by PostgreSQL
# - Setup:
#     1. Create ~/.pgpass with: hostname:port:database:username:password
#     2. Set permissions: chmod 600 ~/.pgpass
#
# For AWS RDS: 'aws_secrets_manager'
# - Retrieves password from AWS Secrets Manager
# - Requires DB_SECRET_NAME and AWS_REGION
#
# For development only: 'env'
# - Reads password directly from DB_PASSWORD
# - NOT RECOMMENDED for production
#
# Default: pgpass
DB_PASSWORD_PROVIDER=pgpass

# If using 'env' provider (NOT RECOMMENDED for production)
# DB_PASSWORD=your_password_here

# If using 'aws_secrets_manager' provider
# DB_SECRET_NAME=zerogex/db/password
# AWS_REGION=us-east-1

# Connection pool configuration
# Default min: 1, max: 10
DB_POOL_MIN=1
DB_POOL_MAX=10

# Data retention period (days)
# Default: 90
DATA_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Main Ingestion Engine Configuration (Real-Time Forward Data)
# Used by: make ingestion-start / make run-ingest / make run-stream
# -----------------------------------------------------------------------------
# Underlying symbol or alias (e.g. SPY, SPX). Aliases are resolved to their
# TradeStation symbols via SYMBOL_ALIASES for API calls, but the alias is what
# gets stored in the database.
# Default: SPY
INGEST_UNDERLYING=SPY

# Multi-symbol ingestion (comma-separated, overrides INGEST_UNDERLYING when set)
# Example: INGEST_UNDERLYINGS=SPY,SPX
INGEST_UNDERLYINGS=

# Number of expiration dates to track.
# When OPTION_ROOT_ALIASES maps the underlying to a weekly-only root (e.g. SPXW),
# expirations are fetched for that root so only weekly dates are returned.
# Default: 3
INGEST_EXPIRATIONS=3

# Number of strikes to track on each side of the current underlying price.
# e.g. 10 = 10 strikes below + 10 strikes above = 20 strikes per expiration.
# The window re-centers automatically every STRIKE_RECALC_INTERVAL iterations.
# Default: 10
INGEST_STRIKE_COUNT=10

# Poll interval during regular market hours (seconds)
# Default: 5
MARKET_HOURS_POLL_INTERVAL=5

# Poll interval during extended hours (pre-market, after-hours) (seconds)
# Default: 30
EXTENDED_HOURS_POLL_INTERVAL=30

# Poll interval when market is closed (seconds)
# Default: 300 (5 minutes)
CLOSED_HOURS_POLL_INTERVAL=300

# How often to re-center the tracked strike window around the latest price.
# One iteration = one poll cycle (MARKET_HOURS_POLL_INTERVAL seconds during market hours).
# At the default 5s poll, STRIKE_RECALC_INTERVAL=12 recalibrates every ~1 minute.
# Default: 12
STRIKE_RECALC_INTERVAL=12

# How often to cleanup expired strikes (iterations)
# Default: 100
STRIKE_CLEANUP_INTERVAL=100

# Session template for streaming data
# Options: Default (9:30-16:00), USEQPre (4:00-9:30), USEQ24Hour (4:00-20:00)
SESSION_TEMPLATE=Default

# Periodic full REST quote reconciliation for option chains (seconds).
# Helps recover any missing fields from partial stream delta payloads.
# Set to 0 to disable.
# Default: 300
OPTION_REST_RECONCILE_INTERVAL_SECONDS=300

# Alert thresholds for option quote field coverage quality checks.
# Coverage is computed each stream iteration as:
#   non-zero field count / total option quotes processed
# Defaults: 35%
OPTION_OI_COVERAGE_ALERT_THRESHOLD=0.35
OPTION_VOLUME_COVERAGE_ALERT_THRESHOLD=0.35

# Enable parity signature logging for ingestion payloads written to:
# - symbols
# - underlying_quotes
# - option_chains
# Emits [PARITY] logs with deterministic payload signature + canonical JSON.
# Default: false
INGEST_PARITY_GUARD_ENABLED=false

# NYSE observed market holidays — comma-separated YYYY-MM-DD dates.
# Used by the /api/market/quote "session" field to determine whether the market
# is open, in pre/after-hours, or closed.  Update this list each year.
NYSE_HOLIDAYS=2024-01-01,2024-01-15,2024-02-19,2024-03-29,2024-05-27,2024-06-19,2024-07-04,2024-09-02,2024-11-28,2024-12-25,2025-01-01,2025-01-09,2025-01-20,2025-02-17,2025-04-18,2025-05-26,2025-06-19,2025-07-04,2025-09-01,2025-11-27,2025-12-25,2026-01-01,2026-01-19,2026-02-16,2026-04-03,2026-05-25,2026-06-19,2026-07-03,2026-09-07,2026-11-26,2026-12-25,2027-01-01,2027-01-18,2027-02-15,2027-03-26,2027-05-31,2027-06-18,2027-07-05,2027-09-06,2027-11-25,2027-12-24

# -----------------------------------------------------------------------------
# Backfill Configuration (Historical Data - Run Independently)
# -----------------------------------------------------------------------------
# IMPORTANT: Backfill is now INDEPENDENT and should be run separately
# Use: python -m src.ingestion.backfill_manager [options]

# Underlying symbol to backfill
# Default: SPY
BACKFILL_UNDERLYING=SPY

# Number of days to look back
# Default: 1
BACKFILL_LOOKBACK_DAYS=1

# Bar interval for backfill (1, 5, 15, 60, etc.)
# Default: 1
BACKFILL_INTERVAL=1

# Bar time unit for backfill: Minute, Daily, Weekly, Monthly
# Default: Minute
BACKFILL_UNIT=Minute

# Number of expirations to backfill
# Default: 3
BACKFILL_EXPIRATIONS=3

# Number of strikes to track on each side of price (same semantics as INGEST_STRIKE_COUNT)
# Default: 10
BACKFILL_STRIKE_COUNT=10

# Sample options every N bars (1 = every bar, 10 = every 10th bar)
# Higher values = faster backfill, less granular data
# Default: 1
BACKFILL_SAMPLE_EVERY=1

# -----------------------------------------------------------------------------
# Data Aggregation Configuration
# -----------------------------------------------------------------------------
# Time bucket size for aggregation (seconds)
# Default: 60 (1 minute)
AGGREGATION_BUCKET_SECONDS=60

# Maximum buffer size before forcing flush
# Default: 1000
MAX_BUFFER_SIZE=1000

# Buffer flush interval (seconds)
# Flush buffers if no data received for this duration
# Default: 60
BUFFER_FLUSH_INTERVAL=60

# -----------------------------------------------------------------------------
# Monitoring & Alerting Configuration
# -----------------------------------------------------------------------------
# Health check interval (seconds)
# Default: 60
HEALTH_CHECK_INTERVAL=60

# Underlying data staleness threshold (seconds)
# Alert if no underlying data received for this duration
# Default: 300 (5 minutes)
UNDERLYING_STALE_THRESHOLD=300

# Option data staleness threshold (seconds)
# Alert if no option data received for this duration
# Default: 600 (10 minutes)
OPTION_STALE_THRESHOLD=600

# Number of consecutive failures before alerting
# Default: 5
CONSECUTIVE_FAILURES_ALERT=5

# Error rate threshold for alerting (percentage)
# Default: 0.1 (10%)
ERROR_RATE_ALERT_THRESHOLD=0.1

# -----------------------------------------------------------------------------
# WebSocket Configuration (Future Enhancement)
# -----------------------------------------------------------------------------
# Enable WebSocket streaming instead of polling
# Default: false
WEBSOCKET_ENABLED=false

# WebSocket reconnection delay (seconds)
# Default: 5.0
WEBSOCKET_RECONNECT_DELAY=5.0

# WebSocket ping interval (seconds)
# Default: 30
WEBSOCKET_PING_INTERVAL=30

# Maximum WebSocket reconnection attempts
# Default: 10
WEBSOCKET_MAX_RECONNECT_ATTEMPTS=10

# -----------------------------------------------------------------------------
# Analytics Engine Configuration
# -----------------------------------------------------------------------------
# Underlying symbol to analyze
ANALYTICS_UNDERLYING=SPY

# Multi-symbol analytics (comma-separated, overrides ANALYTICS_UNDERLYING when set)
# Example: ANALYTICS_UNDERLYINGS=SPY,SPX
ANALYTICS_UNDERLYINGS=

# Calculation interval (seconds)
ANALYTICS_INTERVAL=60

# Lookback window (minutes) used to build a per-contract latest snapshot for GEX.
# This avoids sparse call/put OI when stream updates are asynchronous across contracts.
# Default: 5
ANALYTICS_SNAPSHOT_LOOKBACK_MINUTES=5

# Freshness gate (seconds) for contract snapshots used in analytics.
# Contracts older than this are excluded from the per-contract latest snapshot.
# Default: 180
ANALYTICS_SNAPSHOT_FRESHNESS_SECONDS=180

# Alert threshold for low OI coverage in analytics snapshots.
# Coverage = contracts with OI>0 / total contracts in snapshot.
# Default: 35%
ANALYTICS_MIN_OI_COVERAGE_PCT_ALERT=0.35

# -----------------------------------------------------------------------------
# Greeks & IV Calculation Configuration
# -----------------------------------------------------------------------------
# Enable real-time Greeks calculations
# Default: true
GREEKS_ENABLED=true

# Enable real-time IV calculation from option prices
# If false, will only use IV provided by API or default IV
# Default: true
IV_CALCULATION_ENABLED=true

# IV Solver Configuration
IV_MAX_ITERATIONS=100
IV_TOLERANCE=0.00001
IV_MIN=0.01
IV_MAX=5.0

# Risk-free rate for Greeks calculation (annual rate)
# Example: 0.05 = 5% annual risk-free rate
# Default: 0.05
RISK_FREE_RATE=0.05

# Default implied volatility if not available from API or calculation
# Example: 0.20 = 20% volatility
# Default: 0.20
IMPLIED_VOLATILITY_DEFAULT=0.20

# -----------------------------------------------------------------------------
# Grafana/Metrics Configuration (Future Enhancement)
# -----------------------------------------------------------------------------
# Enable Prometheus metrics endpoint
# Default: false
METRICS_ENABLED=false

# Port for Prometheus metrics endpoint
# Default: 9090
METRICS_PORT=9090

# Enable Grafana dashboard integration
# Default: false
GRAFANA_DASHBOARD_ENABLED=false

# -----------------------------------------------------------------------------
# Example Production Configuration
# -----------------------------------------------------------------------------
# For production deployment, you might use:
#
# LOG_LEVEL=INFO
# API_RETRY_ATTEMPTS=5
# MARKET_HOURS_POLL_INTERVAL=1
# EXTENDED_HOURS_POLL_INTERVAL=10
# WEBSOCKET_ENABLED=true
# GEX_ENABLED=true
# GREEKS_ENABLED=true
# METRICS_ENABLED=true
# GRAFANA_DASHBOARD_ENABLED=true
# DB_PASSWORD_PROVIDER=aws_secrets_manager
#
# IMPORTANT: Run backfill independently for historical data:
#   python -m src.ingestion.backfill_manager --lookback-days 30
